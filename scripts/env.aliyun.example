# 阿里云 PostgreSQL 连接配置示例
# 复制此文件为 .env.aliyun 并填写实际值
# 注意: .env.aliyun 已加入 .gitignore，不会被提交到仓库

# 备份文件路径
BACKUP_FILE=supabase_backup.dump

# 数据库主机 (本地导入使用 localhost，远程导入使用服务器 IP)
DB_HOST=localhost

# 端口 (默认 5432)
DB_PORT=5432

# 目标数据库名
DB_NAME=your_db_name

# 数据库用户 (通常是 postgres)
DB_USER=postgres

# 数据库密码
DB_PASSWORD=your_password_here

