# Supabase 数据库连接配置示例
# 复制此文件为 .env.supabase 并填写实际值
# 注意: .env.supabase 已加入 .gitignore，不会被提交到仓库

# Supabase 数据库主机地址
# 格式: db.xxx.supabase.co
SUPABASE_HOST=db.xxx.supabase.co

# 端口 (通常是 5432)
SUPABASE_PORT=5432

# 数据库名 (通常是 postgres)
SUPABASE_DB=postgres

# 用户名 (通常是 postgres)
SUPABASE_USER=postgres

# 密码 (在 Supabase Dashboard → Settings → Database 中查看)
SUPABASE_PASSWORD=your_password_here

